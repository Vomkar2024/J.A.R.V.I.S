# ============================================================
# J.A.R.V.I.S — Central Configuration Template
# Copy this file to `.env` and populate with real values.
# `.env` is git-ignored and MUST NEVER be committed.
# ============================================================

# --- Backend ---
# Obtain a key at https://console.groq.com/
GROQ_API_KEY=gsk_replace_me_with_real_key

# Port the FastAPI server binds to
BACKEND_PORT=8000

# Comma-separated origins permitted by CORS (no wildcards in production)
ALLOWED_ORIGINS=http://localhost:3000

# Sandbox root for file-system tools (absolute path). Defaults to the
# project root if unset. Tool operations are restricted to this subtree.
JARVIS_SANDBOX_ROOT=

# --- Frontend ---
PORT=3000
REACT_APP_API_URL=http://localhost:8000
