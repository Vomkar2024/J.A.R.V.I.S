{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "J.A.R.V.I.S",
  "version": "3.2.0",
  "identifier": "ai.jarvis.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend start",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../frontend/build"
  },
  "app": {
    "windows": [
      {
        "title": "J.A.R.V.I.S",
        "label": "main",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "center": true,
        "visible": false,
        "titleBarStyle": "Visible",
        "backgroundColor": "#050507",
        "windowEffects": {
          "effects": ["mica"]
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self' http://127.0.0.1:8000 ws://127.0.0.1:8000; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "category": "Productivity",
    "shortDescription": "Voice-first AI desktop assistant",
    "longDescription": "J.A.R.V.I.S — sandboxed shell tools, AES-256-GCM vault, real-time streaming LLM on a Three.js HUD.",
    "publisher": "Shubham",
    "copyright": "Copyright © 2026",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [
      "binaries/jarvis-core"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {}
}
